{
  "expo": {
    "name": "VK Drop Taxi",
    "slug": "vk-drop-taxi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/vk-drop-logo.jpg",
    "scheme": "vkdroptaxi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "alias": {
        "react-native-maps": "./web-mocks/react-native-maps.js",
        "expo-image-picker": "./web-mocks/expo-image-picker.js",
        "expo-location": "./web-mocks/expo-location.js"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/vk-drop-logo.jpg",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#FFC107"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
